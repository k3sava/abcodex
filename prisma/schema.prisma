generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }
model User { id String @id @default(cuid()) email String @unique name String? projects Project[] createdAt DateTime @default(now()) }
model Project { id String @id @default(cuid()) name String category String icp String? description String? ownerId String? owner User? @relation(fields: [ownerId], references: [id]) sources Source[] rawRecords RawRecord[] processedRecords ProcessedRecord[] clusters Cluster[] opportunities Opportunity[] reports Report[] savedInsights SavedInsight[] runs Run[] createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model Source { id String @id @default(cuid()) projectId String project Project @relation(fields: [projectId], references: [id], onDelete: Cascade) type String name String query String? url String? config Json? status String @default("active") createdAt DateTime @default(now()) }
model RawRecord { id String @id @default(cuid()) projectId String project Project @relation(fields: [projectId], references: [id], onDelete: Cascade) source String sourceUrl String? author String? date DateTime? title String? body String product String? engagement Int? rawPayload Json? ingestedAt DateTime @default(now()) processed ProcessedRecord? classifications Classification[] embeddings Embedding[] }
model ProcessedRecord { id String @id @default(cuid()) projectId String project Project @relation(fields: [projectId], references: [id], onDelete: Cascade) rawRecordId String @unique rawRecord RawRecord @relation(fields: [rawRecordId], references: [id], onDelete: Cascade) cleanedText String language String? entities Json? productNames String[] competitorNames String[] workflowVerbs String[] toolStack String[] complaintPhrases String[] fingerprint String createdAt DateTime @default(now()) }
model Classification { id String @id @default(cuid()) rawRecordId String rawRecord RawRecord @relation(fields: [rawRecordId], references: [id], onDelete: Cascade) signalType String painCategory String emotionalIntensity Int urgency Int persona String? productArea String? workflowStep String? willingnessToPaySignal Boolean @default(false) workaroundPresent Boolean @default(false) competitorsMentioned String[] toolsMentioned String[] summary String quotableLanguage String? confidence Float why String? promptLog Json? createdAt DateTime @default(now()) }
model Embedding { id String @id @default(cuid()) rawRecordId String rawRecord RawRecord @relation(fields: [rawRecordId], references: [id], onDelete: Cascade) provider String model String dimensions Int vector Unsupported("vector")? vectorJson Json? createdAt DateTime @default(now()) }
model Cluster { id String @id @default(cuid()) projectId String project Project @relation(fields: [projectId], references: [id], onDelete: Cascade) name String description String recordIds String[] representativeQuotes String[] sourceMix Json personas String[] productsMentioned String[] frequency Int emotionalIntensity Float opportunityScore Int evidenceStrength Int recommendedProductWedge String recommendedPmmAngle String createdAt DateTime @default(now()) updatedAt DateTime @updatedAt opportunities Opportunity[] }
model Opportunity { id String @id @default(cuid()) projectId String project Project @relation(fields: [projectId], references: [id], onDelete: Cascade) clusterId String? cluster Cluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull) title String targetUser String problemStatement String existingAlternatives String[] whyCurrentToolsFail String mvpScope String[] willingnessToPayHypothesis String pricingHypothesis String distributionChannels String[] validationPlan String[] risks String[] moatPossibilities String[] whyNow String consultingRelevance String buildRecommendation String score Int evidenceRecordIds String[] createdAt DateTime @default(now()) }
model Report { id String @id @default(cuid()) projectId String project Project @relation(fields: [projectId], references: [id], onDelete: Cascade) type String title String markdown String status String @default("ready") createdAt DateTime @default(now()) exports Export[] }
model SavedInsight { id String @id @default(cuid()) projectId String project Project @relation(fields: [projectId], references: [id], onDelete: Cascade) rawRecordId String? clusterId String? opportunityId String? note String? useful Boolean? tags Tag[] createdAt DateTime @default(now()) }
model Tag { id String @id @default(cuid()) name String color String? insights SavedInsight[] }
model Run { id String @id @default(cuid()) projectId String project Project @relation(fields: [projectId], references: [id], onDelete: Cascade) type String status String startedAt DateTime @default(now()) finishedAt DateTime? stats Json? error String? }
model Export { id String @id @default(cuid()) reportId String report Report @relation(fields: [reportId], references: [id], onDelete: Cascade) format String path String? createdAt DateTime @default(now()) }
